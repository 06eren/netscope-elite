{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetScope Pro Analyzer",
  "version": "2.0.0",
  "identifier": "com.netscope.pro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NetScope Elite - Network Intelligence Platform",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 750,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
